# ── API keys de los providers LLM ──────────────────────────────────────────
# Completa las que tengas; las que dejes vacías se OMITEN automáticamente de
# la cadena orquestada (Brain rota entre las configuradas si alguna falla).
# Cadena calidad-primero: groq → cerebras → openrouter → hf
# Guía paso a paso para obtener cada key: docs/API_KEYS.md

# Groq (Llama 3.3 70B) — https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Hugging Face — https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Conectores Meta (opcional) ─────────────────────────────────────────────
# El mismo token sirve para meta_ads y facebook_page (scopes: ads_read,
# pages_show_list, pages_read_engagement; + pages_read_user_content para
# reacciones/comentarios de la página).
# Token de Facebook Login con scope ads_read (Meta Developers → tu app →
# Herramientas → Explorador de la API Graph) y el ID de la cuenta publicitaria
# (Business Manager → Configuración → Cuentas publicitarias; con o sin "act_").
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ── Storage opcional (Google Sheets vía Apps Script) ───────────────────────
# URL del Web App de GAS (ver docs/GAS_SNIPPET.gs). Vacío = solo storage local.
BRAIN_GAS_URL=
